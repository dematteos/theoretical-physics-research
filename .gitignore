# ============================================================
# .gitignore — theoretical-physics-research
# Python + C + HPC + CLASS + MCMC
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.env
*.egg-info/
dist/
build/
.ipynb_checkpoints/
*.ipynb_checkpoints
.pytest_cache/

# --- Jupyter ---
.jupyter/
*.ipynb checkpoints

# --- C / C++ ---
*.o
*.a
*.out
*.exe
*.d
*.so
*.dylib
build/
cmake-build-*/
Makefile.in

# --- CLASS outputs ---
class/outputs/*.dat
class/outputs/*.fits
class/outputs/*.pk
class/outputs/*.cl
class/outputs/

# --- MCMC chains (can be large) ---
mcmc/chains/*.txt
mcmc/chains/*.dat
mcmc/chains/*.h5
mcmc/chains/

# --- Data files (large) ---
data/raw/
data/processed/*.fits
data/processed/*.hdf5
*.fits
*.hdf5
*.h5
*.npy
*.npz

# --- LaTeX auxiliary files ---
latex/**/*.aux
latex/**/*.log
latex/**/*.bbl
latex/**/*.blg
latex/**/*.fls
latex/**/*.fdb_latexmk
latex/**/*.synctex.gz
latex/**/*.toc
latex/**/*.out
latex/**/*.pdf

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Environment ---
.env
*.cfg
!cobaya.cfg
secrets.yaml
